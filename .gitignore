# Entornos virtuales
venv/
env/
.venv/
ENV/

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Django
*.log
local_settings.py
db.sqlite3
*.sqlite3
*.db
*.sql
media/
staticfiles/
static_collected/

# Variables de entorno
.env
.env.*

# IDEs y editores
.vscode/
.idea/
*.swp
*.swo
*~

# Sistemas operativos
.DS_Store
Thumbs.db
desktop.ini

# Migraciones generadas localmente (opcional — descomenta si aplica)
